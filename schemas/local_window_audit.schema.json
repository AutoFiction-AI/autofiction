{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "cycle",
    "window_id",
    "chapters_reviewed",
    "summary",
    "findings"
  ],
  "additionalProperties": false,
  "properties": {
    "cycle": {
      "type": "integer",
      "minimum": 1
    },
    "window_id": {
      "type": "string",
      "minLength": 1
    },
    "chapters_reviewed": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^chapter_[0-9]{2}$"
      },
      "minItems": 2
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "category",
          "subcategory",
          "severity",
          "chapter_id",
          "evidence",
          "problem",
          "rewrite_direction",
          "acceptance_test",
          "fix_owner_reason",
          "pass_hint"
        ],
        "additionalProperties": false,
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "subcategory": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "chapter_id": {
            "type": "string",
            "pattern": "^chapter_[0-9]{2}$"
          },
          "related_chapter_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^chapter_[0-9]{2}$"
            }
          },
          "boundary_span": {
            "type": "string"
          },
          "counterpart_evidence": {
            "type": "string"
          },
          "pass_hint": {
            "type": "string",
            "enum": [
              "p1_structural_craft",
              "p2_dialogue_idiolect_cadence",
              "p3_prose_copyedit"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "problem": {
            "type": "string",
            "minLength": 1
          },
          "rewrite_direction": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_test": {
            "type": "string",
            "minLength": 1
          },
          "fix_owner_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
