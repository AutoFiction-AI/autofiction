{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "chapter_id",
    "cycle",
    "exchanges_indexed",
    "summary",
    "findings"
  ],
  "additionalProperties": false,
  "properties": {
    "chapter_id": {
      "type": "string",
      "pattern": "^chapter_[0-9]{2}$"
    },
    "cycle": {
      "type": "integer",
      "minimum": 1
    },
    "exchanges_indexed": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^exchange_[0-9]{2}$"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "subcategory",
          "severity",
          "chapter_id",
          "exchange_id",
          "evidence",
          "problem",
          "rewrite_direction",
          "acceptance_test",
          "pass_hint"
        ],
        "additionalProperties": false,
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "subcategory": {
            "type": "string",
            "enum": [
              "dialogue_does_no_work",
              "interchangeable_voices",
              "ceremonial_register_overapplied",
              "narrator_paraphrase_dialogue_patch",
              "affirmative_volley",
              "adverbial_tag_or_telling_tag",
              "scene_stake_unregistered",
              "exchange_overlong_for_beat",
              "trailing_topic_add"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "chapter_id": {
            "type": "string",
            "pattern": "^chapter_[0-9]{2}$"
          },
          "exchange_id": {
            "type": "string",
            "pattern": "^exchange_[0-9]{2}$"
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "problem": {
            "type": "string",
            "minLength": 1
          },
          "rewrite_direction": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_test": {
            "type": "string",
            "minLength": 1
          },
          "pass_hint": {
            "type": "string",
            "enum": [
              "p1_structural_craft",
              "p2_dialogue_idiolect_cadence",
              "p3_prose_copyedit"
            ]
          }
        }
      }
    }
  }
}
