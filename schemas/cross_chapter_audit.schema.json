{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "cycle",
    "summary",
    "redundancy_findings",
    "consistency_findings"
  ],
  "additionalProperties": false,
  "properties": {
    "cycle": {
      "type": "integer",
      "minimum": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "redundancy_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "category",
          "subcategory",
          "severity",
          "chapter_id",
          "evidence",
          "problem",
          "rewrite_direction",
          "acceptance_test"
        ],
        "additionalProperties": true,
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "redundancy"
            ]
          },
          "subcategory": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "chapter_id": {
            "type": "string",
            "pattern": "^chapter_[0-9]{2}$"
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "problem": {
            "type": "string",
            "minLength": 1
          },
          "rewrite_direction": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_test": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "consistency_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "category",
          "subcategory",
          "severity",
          "chapter_id",
          "evidence",
          "problem",
          "rewrite_direction",
          "acceptance_test"
        ],
        "additionalProperties": true,
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "consistency"
            ]
          },
          "subcategory": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "chapter_id": {
            "type": "string",
            "pattern": "^chapter_[0-9]{2}$"
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "problem": {
            "type": "string",
            "minLength": 1
          },
          "rewrite_direction": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_test": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
