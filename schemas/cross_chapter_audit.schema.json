{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "cycle",
    "summary",
    "not_x_y_count",
    "personified_abstraction_count",
    "abstract_noun_subject_count",
    "simile_count",
    "as_if_count",
    "the_way_x_count",
    "pacing_mismatch_count",
    "redundancy_findings",
    "consistency_findings",
    "pacing_mismatch_findings"
  ],
  "additionalProperties": false,
  "properties": {
    "cycle": {
      "type": "integer",
      "minimum": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "not_x_y_count": {
      "type": "integer",
      "minimum": 0
    },
    "personified_abstraction_count": {
      "type": "integer",
      "minimum": 0
    },
    "abstract_noun_subject_count": {
      "type": "integer",
      "minimum": 0
    },
    "simile_count": {
      "type": "integer",
      "minimum": 0
    },
    "as_if_count": {
      "type": "integer",
      "minimum": 0
    },
    "the_way_x_count": {
      "type": "integer",
      "minimum": 0
    },
    "pacing_mismatch_count": {
      "type": "integer",
      "minimum": 0
    },
    "redundancy_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "category",
          "subcategory",
          "severity",
          "chapter_id",
          "evidence",
          "problem",
          "rewrite_direction",
          "acceptance_test"
        ],
        "additionalProperties": true,
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "redundancy"
            ]
          },
          "subcategory": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "chapter_id": {
            "type": "string",
            "pattern": "^chapter_[0-9]{2}$"
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "problem": {
            "type": "string",
            "minLength": 1
          },
          "rewrite_direction": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_test": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "consistency_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "category",
          "subcategory",
          "severity",
          "chapter_id",
          "evidence",
          "problem",
          "rewrite_direction",
          "acceptance_test"
        ],
        "additionalProperties": true,
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "consistency"
            ]
          },
          "subcategory": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "chapter_id": {
            "type": "string",
            "pattern": "^chapter_[0-9]{2}$"
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "problem": {
            "type": "string",
            "minLength": 1
          },
          "rewrite_direction": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_test": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "pacing_mismatch_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "chapter_id",
          "beat",
          "importance",
          "target_words",
          "actual_words",
          "evidence",
          "severity",
          "problem",
          "rewrite_direction",
          "acceptance_test"
        ],
        "additionalProperties": true,
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "chapter_id": {
            "type": "string",
            "pattern": "^chapter_[0-9]{2}$"
          },
          "beat": {
            "type": "string",
            "minLength": 1
          },
          "importance": {
            "type": "string",
            "enum": [
              "primary",
              "secondary",
              "bridge"
            ]
          },
          "target_words": {
            "type": "integer",
            "minimum": 0
          },
          "actual_words": {
            "type": "integer",
            "minimum": 0
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "problem": {
            "type": "string",
            "minLength": 1
          },
          "rewrite_direction": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_test": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
