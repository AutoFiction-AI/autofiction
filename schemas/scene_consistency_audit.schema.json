{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "chapter_id",
    "cycle",
    "scenes_indexed",
    "summary",
    "findings"
  ],
  "additionalProperties": false,
  "properties": {
    "chapter_id": {
      "type": "string",
      "pattern": "^chapter_[0-9]{2}$"
    },
    "cycle": {
      "type": "integer",
      "minimum": 1
    },
    "scenes_indexed": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^scene_[0-9]{2}$"
      },
      "minItems": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "subcategory",
          "severity",
          "chapter_id",
          "scene_id",
          "evidence",
          "problem",
          "rewrite_direction",
          "acceptance_test",
          "pass_hint"
        ],
        "additionalProperties": false,
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "subcategory": {
            "type": "string",
            "enum": [
              "commonsense_physical",
              "prop_state_local",
              "blocking_contradiction",
              "light_environment",
              "time_within_scene",
              "knowledge_state_local",
              "emotional_continuity_local",
              "action_decision_local",
              "description_contradiction_local",
              "social_action_coherence",
              "dialogue_internal_coherence"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "chapter_id": {
            "type": "string",
            "pattern": "^chapter_[0-9]{2}$"
          },
          "scene_id": {
            "type": "string",
            "pattern": "^scene_[0-9]{2}$"
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "problem": {
            "type": "string",
            "minLength": 1
          },
          "rewrite_direction": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_test": {
            "type": "string",
            "minLength": 1
          },
          "pass_hint": {
            "type": "string",
            "enum": [
              "p1_structural_craft",
              "p2_dialogue_idiolect_cadence",
              "p3_prose_copyedit"
            ]
          }
        }
      }
    }
  }
}
