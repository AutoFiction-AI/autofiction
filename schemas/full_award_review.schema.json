{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "cycle",
    "verdict",
    "summary",
    "findings"
  ],
  "properties": {
    "cycle": {
      "type": "integer",
      "minimum": 1
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "severity",
          "chapter_id",
          "evidence",
          "problem",
          "rewrite_direction",
          "acceptance_test"
        ],
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "chapter_id": {
            "type": "string",
            "pattern": "^chapter_[0-9]{2}$"
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "problem": {
            "type": "string",
            "minLength": 1
          },
          "rewrite_direction": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_test": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "pattern_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pattern_id",
          "severity",
          "global_problem",
          "affected_chapters",
          "chapter_hits"
        ],
        "properties": {
          "pattern_id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "global_problem": {
            "type": "string",
            "minLength": 1
          },
          "global_rewrite_principles": {
            "type": "string",
            "minLength": 1
          },
          "affected_chapters": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^chapter_[0-9]{2}$"
            }
          },
          "chapter_hits": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "chapter_id",
                "evidence",
                "problem",
                "rewrite_direction",
                "acceptance_test"
              ],
              "properties": {
                "finding_id": {
                  "type": "string",
                  "minLength": 1
                },
                "chapter_id": {
                  "type": "string",
                  "pattern": "^chapter_[0-9]{2}$"
                },
                "evidence": {
                  "type": "string",
                  "minLength": 1
                },
                "problem": {
                  "type": "string",
                  "minLength": 1
                },
                "rewrite_direction": {
                  "type": "string",
                  "minLength": 1
                },
                "acceptance_test": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
