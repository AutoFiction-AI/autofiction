{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["chapter_id", "verdicts", "findings", "summary"],
  "properties": {
    "chapter_id": {
      "type": "string",
      "pattern": "^chapter_[0-9]{2}$"
    },
    "verdicts": {
      "type": "object",
      "required": ["award", "craft", "dialogue", "prose"],
      "properties": {
        "award": { "type": "string", "enum": ["PASS", "FAIL"] },
        "craft": { "type": "string", "enum": ["PASS", "FAIL"] },
        "dialogue": { "type": "string", "enum": ["PASS", "FAIL"] },
        "prose": { "type": "string", "enum": ["PASS", "FAIL"] }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "source",
          "severity",
          "chapter_id",
          "evidence",
          "problem",
          "rewrite_direction",
          "acceptance_test"
        ],
        "properties": {
          "finding_id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "enum": ["award", "craft", "dialogue", "prose"] },
          "severity": { "type": "string", "enum": ["MEDIUM", "HIGH", "CRITICAL"] },
          "chapter_id": { "type": "string", "pattern": "^chapter_[0-9]{2}$" },
          "evidence": { "type": "string", "minLength": 1 },
          "problem": { "type": "string", "minLength": 1 },
          "rewrite_direction": { "type": "string", "minLength": 1 },
          "acceptance_test": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "summary": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
